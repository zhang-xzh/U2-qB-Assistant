{
  "manifest_version": 3,
  "name": "U2 助手 - 站点增强工具",
  "version": "7.0.0",
  "description": "U2 增强工具",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["*://u2.dmhy.org/*", "http://localhost:18000/"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://u2.dmhy.org/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_end"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon.png"
  }
}