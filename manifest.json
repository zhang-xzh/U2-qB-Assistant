{
  "manifest_version": 3,
  "name": "NexusPHP qB 自动关联助手",
  "version": "6.4.4",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["*://u2.dmhy.org/*", "http://localhost:18000/"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://u2.dmhy.org/torrents.php*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_end"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "128": "icon.png"
  }
}